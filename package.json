{
  "name": "github-runner-fleet",
  "private": true,
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist-server/status-app/server.js",
    "test": "npm run test:frontend && npm run test:backend",
    "test:backend": "c8 --check-coverage --lines 85 --functions 85 --branches 85 --statements 85 --include=status-app/*.ts --exclude=status-app/*.test.ts --exclude=status-app/cleanup.ts tsx --test status-app/*.test.ts",
    "test:frontend": "vitest run --coverage",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "c8": "^10.1.3",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "tsx": "^4.20.5",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
