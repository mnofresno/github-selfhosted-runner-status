REPO_URL=
ACCESS_TOKEN=
RUNNER_NAME=
STATUS_PORT=3571
COMPOSE_PROJECT_NAME=github-selfhosted
RUNNER_IMAGE=myoung34/github-runner:latest
RUNNER_WORKDIR=/tmp/github-runner
LABELS=self-hosted,linux,x64
RUNNER_TARGETS_JSON=[{"id":"bpf-application","name":"BPF Application","scope":"repo","owner":"bpf-project","repo":"bpf-application","labels":["self-hosted","linux","x64","bpf"],"description":"Dedicated repo-scoped runners for the main BPF app"},{"id":"gymnerd-bot","name":"GymNerd Bot","scope":"repo","owner":"gymnerd-ar","repo":"gymnerd-bot","labels":["self-hosted","linux","x64","gymnerd"],"description":"Dedicated repo-scoped runners for GymNerd"},{"id":"bpf-org-shared","name":"BPF Shared Org Fleet","scope":"org","owner":"bpf-project","runnerGroup":"Default","labels":["self-hosted","linux","x64","shared"],"description":"Optional org-scoped pool for trusted repos in the same org"}]
