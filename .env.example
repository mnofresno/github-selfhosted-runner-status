ACCESS_TOKEN=
STATUS_BIND=127.0.0.1:3571
STATUS_INTERNAL_PORT=8080
STATUS_PORT=8080
HEALTHCHECK_INTERVAL_MS=15000
CLEANUP_ENABLED=true
CLEANUP_INTERVAL_MS=3600000
CLEANUP_COOLDOWN_MS=900000
CLEANUP_DANGLING_MAX_AGE=96h
CLEANUP_BUILD_CACHE_MAX_AGE=96h
STACK_GRACE_MS=30m
GLOBAL_PRUNE_EXCLUDE_LABELS=io.github-runner-fleet.managed=true
RUNNERS_PER_TARGET=1
RUNNER_IMAGE=myoung34/github-runner:latest
RUNNER_WORKDIR=/tmp/github-runner
DIND_IMAGE=docker:27-dind
LABELS=self-hosted,linux,x64
RUNNER_TARGETS_JSON=[{"id":"bpf-org","name":"BPF Shared Org Fleet","scope":"org","owner":"bpf-project","repo":"bpf-application","runnerGroup":"Default","labels":["self-hosted","linux","x64","bpf-org","shared"],"runnersCount":1,"description":"Shared org-level runners for BPF repositories"},{"id":"gymnerd-org","name":"GymNerd Org Fleet","scope":"org","owner":"gymnerd-ar","repo":"gymnerd-bot","runnerGroup":"Default","labels":["self-hosted","linux","x64","gymnerd","shared"],"runnersCount":1,"description":"Shared org-level runners for GymNerd repositories"}]
